# Database connection
DB_PASSWORD=changeme
DB_HOST=db
DB_PORT=5432
DB_NAME=softwarechecker
DB_USER=checker

# Container names (used as hostnames on Docker networks, e.g. for nginx proxy manager)
DB_CONTAINER_NAME=softwarechecker-db
BACKEND_CONTAINER_NAME=softwarechecker-backend
FRONTEND_CONTAINER_NAME=softwarechecker-frontend

# GitHub (optional — raises API rate limit from 60 to 5000 req/hour)
GITHUB_TOKEN=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Web Push VAPID (generated automatically on first run if empty)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Backend
PORT=3000
NODE_ENV=production

# Frontend
HTTP_PORT=80
